    {
      "name": "Pipeline",
      "item": [
        {
          "name": "Create Pipeline",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.trace_id) pm.collectionVariables.set('trace_id', data.trace_id);",
                  "if (data.alert_id) pm.collectionVariables.set('alert_id', String(data.alert_id));",
                  "if (data.prediction_id) pm.collectionVariables.set('prediction_id', String(data.prediction_id));",
                  "if (data.investigation_id) pm.collectionVariables.set('investigation_id', String(data.investigation_id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alert\": {\n    \"external_alert_id\": \"{{external_alert_id}}\",\n    \"alert_name\": \"UAC Bypass via Sdclt.exe on host test-host01.local\",\n    \"source\": \"Mock SIEM\",\n    \"severity\": \"High\",\n    \"detected_time\": \"2026-04-01T12:00:00\",\n    \"status\": \"RECEIVED\",\n    \"raw_log\": {\n      \"alert_status\": \"Closed\",\n      \"case_result\": \"FalsePositives\",\n      \"contexts\": {\n        \"os\": \"windows 11 22621\",\n        \"user\": \"test-host01$\",\n        \"src_ip\": [\n          \"10.0.1.15\"\n        ]\n      },\n      \"events\": [\n        {\n          \"event_id\": \"evt001\",\n          \"description\": \"Sdclt.exe executed\"\n        }\n      ]\n    }\n  },\n  \"type\": {\n    \"main_tactic\": \"T1059\",\n    \"main_technique\": \"Command and Scripting Interpreter\",\n    \"confidence\": 0.97,\n    \"mitre_matches\": [\n      {\n        \"tacticID\": \"T1059\",\n        \"confidence\": 1\n      }\n    ],\n    \"prediction\": {\n      \"tactic\": [\n        \"Execution\"\n      ],\n      \"technique\": [\n        \"Command and Scripting Interpreter\"\n      ]\n    },\n    \"source\": \"Existing_MITRE\",\n    \"status\": \"PENDING\"\n  },\n  \"context\": {\n    \"src_ip\": \"10.0.1.15\",\n    \"host\": \"test-host01.local\",\n    \"user_name\": \"test-host01$\",\n    \"context_data\": {\n      \"os\": \"windows 11 22621\"\n    },\n    \"status\": \"PENDING\"\n  },\n  \"investigation\": {\n    \"verdict\": \"Malicious\",\n    \"severity\": \"High\",\n    \"confidence\": \"High\",\n    \"summary\": \"Potential UAC bypass behavior detected.\",\n    \"investigation_data\": {\n      \"logClassification\": {\n        \"type\": \"UAC Bypass\"\n      }\n    },\n    \"status\": \"PROCESSING\",\n    \"prompt_send\": \"Analyze the alert, correlate the context, and explain whether containment is needed.\",\n    \"recommendations\": [\n      {\n        \"type\": \"soc\",\n        \"content\": \"Validate execution chain and isolate the endpoint if confirmed malicious.\",\n        \"status\": \"PENDING\"\n      },\n      {\n        \"type\": \"customer\",\n        \"content\": \"Please verify unusual behavior on this endpoint and report if expected.\",\n        \"status\": \"PENDING\"\n      }\n    ]\n  }\n}"
            },
            "url": "{{base_url}}{{api_prefix}}/pipeline/"
          }
        }
