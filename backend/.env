# Application
APP_NAME=SOC-Agentic-API
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8181

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]

# Database (PostgreSQL)
DATABASE_URL=postgresql://soc_user:soc_pass@localhost:5432/soc_db

# Redis (for job queues / caching)
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Agent Config
AGENT_MAX_CONCURRENT=5
AGENT_TIMEOUT_SECONDS=300

# External Integrations (optional)
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
MISP_URL=
MISP_KEY=
# PAIAC upstream API
PUBLIC_DOMAIN=false
PAIAC_PUBLIC_BASE_URL=https://db.paiac.store
PAIAC_LOCAL_BASE_URL=http://host.docker.internal:8000
PAIAC_API_PREFIX=
PAIAC_TIMEOUT_SECONDS=20
