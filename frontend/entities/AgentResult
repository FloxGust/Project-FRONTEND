{
  "name": "AgentResult",
  "type": "object",
  "properties": {
    "alert_id": {
      "type": "string",
      "description": "Reference to the alert"
    },
    "agent_name": {
      "type": "string",
      "enum": [
        "TypeAgent",
        "ContextAgent",
        "InvestigationAgent"
      ],
      "description": "Name of the AI agent"
    },
    "result": {
      "type": "object",
      "description": "AI analysis output",
      "properties": {
        "classification_type": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "mitre_tactic": {
          "type": "string"
        },
        "mitre_technique": {
          "type": "string"
        },
        "mitre_sub_technique": {
          "type": "string"
        },
        "key_entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "behavior_factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "overall_verdict": {
          "type": "string"
        }
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low"
      ],
      "description": "Confidence level of the analysis"
    },
    "processed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the agent processed the alert"
    }
  },
  "required": [
    "alert_id",
    "agent_name",
    "confidence"
  ]
}